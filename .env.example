# PostgreSQL
POSTGRES_DB=forgelab
POSTGRES_USER=forgelab_user
POSTGRES_PASSWORD=forgelab_password
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# API
API_PORT=4000

# Frontend
VITE_API_URL=http://localhost:4000


DATABASE_URL=postgresql://forgelab_user:forgelab_password@localhost:5432/forgelab

# Authentication
AUTH_ACCESS_TOKEN_SECRET=replace_this_with_a_long_random_secret_of_at_least_32_characters
AUTH_ACCESS_TOKEN_EXPIRES_IN=15m
AUTH_TOKEN_ISSUER=forgelab-api
AUTH_TOKEN_AUDIENCE=forgelab-web