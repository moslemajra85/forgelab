{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src", "generated","prisma", "prisma.config.ts"]
}
